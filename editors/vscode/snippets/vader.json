{
  "public function": {
    "prefix": "pfn",
    "body": ["public fn ${1:name}(${2:params}): ${3:type} {", "\t$0", "}"],
    "description": "public fn name(params): type { }"
  },
  "function": {
    "prefix": "fn",
    "body": ["fn ${1:name}(${2:params}): ${3:type} {", "\t$0", "}"],
    "description": "fn name(params): type { }"
  },
  "function (no return)": {
    "prefix": "fnv",
    "body": ["fn ${1:name}(${2:params}) {", "\t$0", "}"],
    "description": "fn name(params) { }  — no return value"
  },
  "public function (no return)": {
    "prefix": "pfnv",
    "body": ["public fn ${1:name}(${2:params}) {", "\t$0", "}"],
    "description": "public fn name(params) { }  — no return value"
  },
  "main": {
    "prefix": "main",
    "body": ["fn main() {", "\t$0", "}"],
    "description": "fn main() entry point"
  },
  "method": {
    "prefix": "method",
    "body": ["fn (${1:r} ${2:Type}) ${3:name}(${4:params}): ${5:type} {", "\t$0", "}"],
    "description": "method: fn (r Type) name(params): type { }"
  },
  "public method": {
    "prefix": "pmethod",
    "body": ["public fn (${1:r} ${2:Type}) ${3:name}(${4:params}): ${5:type} {", "\t$0", "}"],
    "description": "public method with a receiver"
  },
  "function returning (T, error)": {
    "prefix": "pfne",
    "body": [
      "public fn ${1:name}(${2:params}): (${3:type}, error) {",
      "\tif ${4:cond} {",
      "\t\treturn ${5:zero}, error(\"${6:message}\")",
      "\t}",
      "\treturn ${7:value}, nil",
      "}"
    ],
    "description": "public fn returning a value plus error"
  },
  "struct": {
    "prefix": "struct",
    "body": ["struct ${1:Name} {", "\t${2:field} ${3:Type}", "}"],
    "description": "struct Name { field Type }"
  },
  "public struct": {
    "prefix": "pstruct",
    "body": ["public struct ${1:Name} {", "\t${2:field} ${3:Type}", "}"],
    "description": "public struct Name { field Type }"
  },
  "interface": {
    "prefix": "interface",
    "body": ["interface ${1:Name} {", "\tfn ${2:method}(${3:params}): ${4:type}", "}"],
    "description": "interface Name { fn method(): type }"
  },
  "public interface": {
    "prefix": "pinterface",
    "body": ["public interface ${1:Name} {", "\tfn ${2:method}(${3:params}): ${4:type}", "}"],
    "description": "public interface with one method"
  },
  "enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "\t${2:Variant}(${3:field Type})", "\t${4:Other}", "}"],
    "description": "enum Name { Variant(field Type) }"
  },
  "public enum": {
    "prefix": "penum",
    "body": ["public enum ${1:Name} {", "\t${2:Variant}(${3:field Type})", "\t${4:Other}", "}"],
    "description": "public enum with variants"
  },
  "match": {
    "prefix": "match",
    "body": ["match ${1:value} {", "\t${2:Pattern}: ${3:result}", "\t_: ${4:default}", "}"],
    "description": "match value { Pattern: result }"
  },
  "if": {
    "prefix": "if",
    "body": ["if ${1:cond} {", "\t$0", "}"],
    "description": "if cond { }"
  },
  "if / else": {
    "prefix": "ife",
    "body": ["if ${1:cond} {", "\t$2", "} else {", "\t$0", "}"],
    "description": "if / else"
  },
  "error check": {
    "prefix": "iferr",
    "body": [
      "${1:int} ${2:result}, error err = ${3:call}",
      "if err != nil {",
      "\treturn ${4:err}",
      "}",
      "$0"
    ],
    "description": "call returning (T, error) + nil check"
  },
  "for (infinite)": {
    "prefix": "for",
    "body": ["for {", "\t$0", "}"],
    "description": "for { } — infinite loop"
  },
  "for (condition)": {
    "prefix": "forc",
    "body": ["for ${1:cond} {", "\t$0", "}"],
    "description": "for cond { } — while-style"
  },
  "for (range)": {
    "prefix": "forr",
    "body": ["for ${1:i} in ${2:0}..${3:n} {", "\t$0", "}"],
    "description": "for i in 0..n { } — exclusive range"
  },
  "for (inclusive range)": {
    "prefix": "forri",
    "body": ["for ${1:i} in ${2:1}..=${3:n} {", "\t$0", "}"],
    "description": "for i in 1..=n { } — inclusive range"
  },
  "for (collection)": {
    "prefix": "forin",
    "body": ["for ${1:item} in ${2:items} {", "\t$0", "}"],
    "description": "for item in items { } — iterate a slice/channel"
  },
  "test": {
    "prefix": "test",
    "body": ["test \"${1:description}\" {", "\tassert ${2:condition}", "}"],
    "description": "test \"...\" { assert ... }"
  },
  "const": {
    "prefix": "const",
    "body": ["const ${1:int} ${2:NAME} = ${3:value}"],
    "description": "const Type NAME = value"
  },
  "import": {
    "prefix": "import",
    "body": ["import \"${1:path}\""],
    "description": "import \"path\""
  },
  "import group": {
    "prefix": "imports",
    "body": ["import (", "\t\"${1:std/db}\"", "\t\"${2:std/json}\"", ")"],
    "description": "grouped imports"
  },
  "spawn": {
    "prefix": "spawn",
    "body": ["spawn ${1:worker}(${2:args})"],
    "description": "spawn a concurrent task"
  },
  "channel": {
    "prefix": "chan",
    "body": ["chan[${1:int}] ${2:ch} = chan[${1:int}](${3:100})"],
    "description": "buffered channel declaration"
  },
  "usecase": {
    "prefix": "usecase",
    "body": [
      "public struct ${1:CreateUser} {",
      "\t${2:repo} ${3:UserRepository}",
      "}",
      "",
      "public fn (uc ${1:CreateUser}) execute(${4:input}): (${5:Result}, error) {",
      "\t$0",
      "}"
    ],
    "description": "Clean Architecture use case (struct + execute)"
  },
  "http handler": {
    "prefix": "handler",
    "body": [
      "public struct ${1:UserHandler} {",
      "\t${2:createUser} ${3:usecase.CreateUser}",
      "}",
      "",
      "public fn (h ${1:UserHandler}) ${4:handleCreate}(${5:params}): (int, error) {",
      "\t$0",
      "\treturn 201, nil",
      "}"
    ],
    "description": "HTTP-layer handler bridging a use case"
  },

  "std/http server": {
    "prefix": "httpserver",
    "body": [
      "import \"std/http\"",
      "",
      "public fn main() {",
      "\tServer ${1:s} = http.listen(${2:8080})",
      "\tfor http.accept(${1:s}) {",
      "\t\tif http.method(${1:s}) == \"${3:GET}\" && http.path(${1:s}) == \"${4:/}\" {",
      "\t\t\thttp.respond(${1:s}, 200, \"${5:text/plain}\", \"${6:ok}\")",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "HTTP server loop with manual path dispatch (std/http)"
  },
  "std/db query": {
    "prefix": "dbquery",
    "body": [
      "import \"std/db\"",
      "",
      "DB ${1:conn} = db.open(\"${2:/tmp/app.db}\")",
      "Rows ${3:rows} = db.query(${1:conn}, \"${4:SELECT id, name FROM users}\")",
      "for db.next(${3:rows}) {",
      "\tint ${5:id} = db.col_int(${3:rows}, 0)",
      "\tstring ${6:name} = db.col_text(${3:rows}, 1)",
      "\tprint(${5:id}, ${6:name})",
      "}",
      "db.close(${1:conn})"
    ],
    "description": "Open a DB and iterate query rows (std/db)"
  },
  "std/json object": {
    "prefix": "jsonbuild",
    "body": [
      "import \"std/json\"",
      "",
      "Json ${1:obj} = json.object()",
      "json.set_str(${1:obj}, \"${2:key}\", \"${3:value}\")",
      "string ${4:out} = json.encode(${1:obj})"
    ],
    "description": "Build and encode a JSON object (std/json)"
  }
}
