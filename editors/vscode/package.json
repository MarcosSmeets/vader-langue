{
  "name": "vader",
  "displayName": "Vader Language",
  "description": "Syntax highlighting, Language Server, and code generation (scaffolding) for the Vader language.",
  "version": "0.5.0",
  "publisher": "Vader",
  "license": "MIT",
  "icon": "icons/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "vader",
    "language",
    "compiler",
    "lsp",
    "syntax-highlighting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcosSmeets/vader-langue.git"
  },
  "bugs": {
    "url": "https://github.com/MarcosSmeets/vader-langue/issues"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:vader"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vader",
        "aliases": [
          "Vader",
          "vader"
        ],
        "extensions": [
          ".vd"
        ],
        "icon": {
          "light": "./icons/vader-file-light.svg",
          "dark": "./icons/vader-file-dark.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vader",
        "scopeName": "source.vader",
        "path": "./syntaxes/vader.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "vader",
        "path": "./snippets/vader.json"
      }
    ],
    "configuration": {
      "title": "Vader",
      "properties": {
        "vader.serverPath": {
          "type": "string",
          "default": "vader",
          "description": "Path to the `vader` executable used as the language server (`vader lsp`). Use an absolute path if it is not on your PATH."
        },
        "vader.enableLanguageServer": {
          "type": "boolean",
          "default": true,
          "description": "Enables the language server (real-time diagnostics). Turn it off to use syntax highlighting only."
        }
      }
    },
    "commands": [
      {
        "command": "vader.gen.struct",
        "title": "Generate Struct",
        "category": "Vader"
      },
      {
        "command": "vader.gen.usecase",
        "title": "Generate Use Case",
        "category": "Vader"
      },
      {
        "command": "vader.gen.handler",
        "title": "Generate Handler",
        "category": "Vader"
      },
      {
        "command": "vader.gen.fn",
        "title": "Generate Function",
        "category": "Vader"
      }
    ],
    "submenus": [
      {
        "id": "vader.genMenu",
        "label": "Vader: Generate"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "vader.genMenu",
          "group": "2_workspace"
        }
      ],
      "editor/context": [
        {
          "submenu": "vader.genMenu",
          "group": "1_modification",
          "when": "editorLangId == vader"
        }
      ],
      "vader.genMenu": [
        {
          "command": "vader.gen.struct"
        },
        {
          "command": "vader.gen.usecase"
        },
        {
          "command": "vader.gen.handler"
        },
        {
          "command": "vader.gen.fn"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm install"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
