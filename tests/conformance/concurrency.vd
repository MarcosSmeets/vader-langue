// channels + goroutines (deterministic: sum of squares)
public fn worker(ch chan[int], n int) {
    int i = 0
    for i < n {
        ch <- i * i
        i = i + 1
    }
}
public fn main() {
    chan[int] ch = chan[int](0)
    spawn worker(ch, 4)
    int sum = 0
    int got = 0
    for got < 4 {
        int v = <-ch
        sum = sum + v
        got = got + 1
    }
    print(sum)
}
