// math_test.vd — ...and its test AUTOMATICALLY GENERATED by the toolchain.
//
// When you create/edit a function in `math.vd`, Vader creates/updates
// this mirror file with a test stub ready to fill in.
// This is the heart of the differentiator: TDD by default, effortless.

test "add returns the sum" {
    int got = add(2, 3)
    assert got == 5
}

test "divide returns the quotient" {
    int got, error err = divide(10, 2)
    assert err == nil
    assert got == 5
}

test "divide by zero returns an error" {
    _, error err = divide(10, 0)
    assert err != nil
}
