// calc.vd — functions + tests, to demonstrate `vader test`.
// `sub` is intentionally NOT tested, so coverage shows < 100%.

fn add(a, b int): int {
    return a + b
}

fn sub(a, b int): int {
    return a - b
}

test "add sums two numbers" {
    assert add(2, 3) == 5
}

test "add is commutative" {
    assert add(1, 2) == add(2, 1)
}
