// calc.vd — funções + testes, para demonstrar `vader test`.
// `sub` de propósito NÃO é testada, para a cobertura aparecer < 100%.

fn add(a, b int): int {
    return a + b
}

fn sub(a, b int): int {
    return a - b
}

test "add soma dois números" {
    assert add(2, 3) == 5
}

test "add é comutativa" {
    assert add(1, 2) == add(2, 1)
}
