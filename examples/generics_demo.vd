// generics_demo.vd — generic functions monomorphized in the LLVM backend.

fn id[T](x T): T {
    return x
}

fn first[T](xs []T): T {
    return xs[0]
}

fn main() {
    print(id(42))          // 42  (instantiates id$i64)

    []int nums = [7, 8, 9]
    print(first(nums))     // 7   (instantiates first$i64)
}
