// Native HTTP server responding JSON — the "great for APIs" pitch.
import "std/http"
import "std/json"

public fn main() {
    Server s = http.listen(8081)
    for http.accept(s) {
        string p = http.path(s)
        Json resp = json.object()
        json.set_str(resp, "path", p)
        json.set_str(resp, "msg", "hello from Vader")
        http.respond(s, 200, "application/json", json.encode(resp))
    }
}
